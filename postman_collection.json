{
  "info": {
    "name": "Shop CO Backend API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000" },
    { "key": "token", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "typeId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ali\",\n  \"lastName\": \"Valiyev\",\n  \"email\": \"ali@example.com\",\n  \"password\": \"StrongPass123\",\n  \"role\": \"user\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"ali@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "Get By Id",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Create (JSON)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Classic Hoodie\",\n  \"description\": \"Warm and comfy hoodie\",\n  \"price\": 49.99,\n  \"type\": \"hoodie\",\n  \"category\": \"men\",\n  \"colors\": [\"black\", \"gray\"],\n  \"size\": [\"S\", \"M\", \"L\"],\n  \"images\": [\n    \"https://res.cloudinary.com/demo/image/upload/v1/hoodie.jpg\"\n  ]\n}"
            }
          }
        },
        {
          "name": "Update",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Classic Hoodie v2\",\n  \"price\": 59.99,\n  \"colors\": [\"black\", \"blue\"]\n}"
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}"]
            }
          }
        },
        {
          "name": "Add Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/products/{{productId}}/comments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "{{productId}}", "comments"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userRate\": 5,\n  \"comment\": \"Juda zo'r mahsulot\"\n}"
            }
          }
        },
        {
          "name": "Upload Image",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/products/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "upload"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "image", "type": "file", "src": "" }]
            }
          }
        },
        {
          "name": "Create With Images",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/products/with-images",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "with-images"]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "images", "type": "file", "src": "" },
                { "key": "images", "type": "file", "src": "" },
                { "key": "title", "type": "text", "value": "Classic Hoodie" },
                {
                  "key": "description",
                  "type": "text",
                  "value": "Warm and comfy hoodie"
                },
                { "key": "price", "type": "text", "value": "49.99" },
                { "key": "type", "type": "text", "value": "hoodie" },
                { "key": "category", "type": "text", "value": "men" },
                { "key": "colors", "type": "text", "value": "black,gray" },
                { "key": "size", "type": "text", "value": "S,M,L" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Types",
      "item": [
        {
          "name": "Get All",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/types",
              "host": ["{{baseUrl}}"],
              "path": ["api", "types"]
            }
          }
        },
        {
          "name": "Create",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/types",
              "host": ["{{baseUrl}}"],
              "path": ["api", "types"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"jacket\"\n}"
            }
          }
        },
        {
          "name": "Delete",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/types/{{typeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "types", "{{typeId}}"]
            }
          }
        }
      ]
    }
  ]
}
